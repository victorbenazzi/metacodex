{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "metacodex",
  "version": "0.0.2",
  "identifier": "com.metacodex.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "metacodex",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Premium local-first developer workspace",
    "longDescription": "metacodex is a local-first developer workspace blending VS Code file navigation, Cursor visual calm, and terminal-native AI coding workflows."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/victorbenazzi/metacodex/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyM0I2NDdDODIzOTlCNUIKUldSYm16bUNmR1E3d2s1NzhwNk5hNnMrUklmdE0xVGZ4Tkg1elpDSHlwbmVzcVF1ZloyOU9pWEIK"
    }
  }
}
