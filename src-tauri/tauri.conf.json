{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "metacodex",
  "version": "0.0.18",
  "identifier": "com.metacodex.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "metacodex",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        },
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://tauri.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' asset: http://asset.localhost data:; worker-src 'self' blob:; child-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Premium local-first developer workspace",
    "longDescription": "metacodex is a local-first developer workspace blending VS Code file navigation, Cursor visual calm, and terminal-native AI coding workflows.",
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx", "txt", "text", "log", "rst"],
        "name": "Markdown & Text",
        "description": "Text or Markdown document",
        "role": "Editor"
      },
      {
        "ext": ["json", "jsonc", "toml", "yaml", "yml", "ini", "csv", "tsv", "xml", "env"],
        "name": "Data & Config",
        "description": "Data or configuration file",
        "role": "Editor"
      },
      {
        "ext": ["js", "mjs", "cjs", "jsx", "ts", "tsx", "vue", "svelte", "html", "htm", "css", "scss", "sass", "less"],
        "name": "Web Source",
        "description": "Web source file",
        "role": "Editor"
      },
      {
        "ext": ["py", "rs", "go", "rb", "php", "java", "kt", "swift", "c", "h", "cpp", "hpp", "cc", "cs", "sh", "bash", "sql", "lua", "graphql"],
        "name": "Source Code",
        "description": "Source code file",
        "role": "Editor"
      },
      {
        "ext": ["png", "jpg", "jpeg", "gif", "webp", "svg", "bmp", "ico", "avif"],
        "name": "Image",
        "description": "Image file",
        "role": "Viewer",
        "mimeType": "image/png"
      },
      {
        "ext": ["pdf"],
        "name": "PDF",
        "description": "PDF document",
        "role": "Viewer",
        "mimeType": "application/pdf"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/victorbenazzi/metacodex/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyM0I2NDdDODIzOTlCNUIKUldSYm16bUNmR1E3d2s1NzhwNk5hNnMrUklmdE0xVGZ4Tkg1elpDSHlwbmVzcVF1ZloyOU9pWEIK"
    }
  }
}
