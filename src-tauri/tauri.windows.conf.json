{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "decorations": false,
        "titleBarStyle": "Visible"
      }
    ]
  },
  "bundle": {
    "windows": {
      "allowDowngrades": true,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "PortugueseBR"]
      }
    }
  }
}
